                                >
                                    ❌ Cancel
                                </button>

                                <button
                                    onClick={confirmUpload}
                                    className="rounded-xl bg-red-600 py-3 font-semibold text-white hover:bg-red-700"
                                >
                                    ⬆️ Upload Questions
                                </button>

                            </div>

                        </div>

                    </div>
                )
            }

        </main>
    );
}
